# Copy this file to `.env` for local development.
# Do not commit real secrets.

LE_ADMIN_APP_NAME=le-admin-server
LE_ADMIN_APP_VERSION=0.1.0
LE_ADMIN_ENVIRONMENT=local
LE_ADMIN_DEBUG=false

LE_ADMIN_API_V1_PREFIX=/api/v1
LE_ADMIN_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

LE_ADMIN_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/le_admin
LE_ADMIN_DATABASE_SCHEMA=le_auth
LE_ADMIN_DATABASE_ECHO=false
LE_ADMIN_CHECK_DATABASE_ON_STARTUP=false

LE_ADMIN_JWT_SECRET=change-me-in-local-development
LE_ADMIN_JWT_ALGORITHM=HS256
LE_ADMIN_ACCESS_TOKEN_EXP_MINUTES=15
LE_ADMIN_REFRESH_TOKEN_EXP_DAYS=14
